{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "client/dist"
      }
    },
    {
      "src": "vercel/api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/vercel/api/[...slug]?slug=$1"
    },
    {
      "src": "/((?:[^/]+\\.)*(?:ico|png|jpg|jpeg|gif|svg|css|js|woff|woff2|ttf|eot|txt|xml|json|map|pdf|zip|rar|7z|tar|gz|bz2|xz))$",
      "dest": "/client/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/client/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
