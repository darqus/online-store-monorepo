# Базовый URL сервера (для локальной разработки)
# VITE_BASE_URL=http://localhost:5000

# URL API (для локальной разработки или кастомной конфигурации)
# VITE_API_URL=http://localhost:5000/api

# Примечание: На Vercel эти переменные не нужны,
# так как используются системные переменные VERCEL_URL и VERCEL_ENV
